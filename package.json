{
  "name": "sysko",
  "version": "0.0.1",
  "private": true,
  "description": "Sysko Observe — zero-config observability for Node.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/syskoio/sysko.git"
  },
  "homepage": "https://github.com/syskoio/sysko#readme",
  "bugs": {
    "url": "https://github.com/syskoio/sysko/issues"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "pack:all": "turbo run build && rimraf dist-packs && pnpm -r --filter \"@sysko/*\" exec pnpm pack --pack-destination ../../dist-packs"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"],
    "patchedDependencies": {
      "@expressots/adapter-express@3.0.0": "patches/@expressots__adapter-express@3.0.0.patch",
      "@expressots/core@3.0.0": "patches/@expressots__core@3.0.0.patch"
    }
  }
}
