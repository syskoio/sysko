{
  "name": "sysko",
  "version": "0.0.1",
  "private": true,
  "description": "Sysko Observe — biblioteca de observabilidade zero-config para Node.js",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "pack:all": "turbo run build && rimraf dist-packs && pnpm -r --filter \"@sysko/*\" exec pnpm pack --pack-destination ../../dist-packs"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
