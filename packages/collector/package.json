{
  "name": "@sysko/collector",
  "version": "0.0.1",
  "description": "Standalone span collector and dashboard for Sysko Observe",
  "license": "MIT",
  "type": "module",
  "bin": {
    "sysko-collector": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@sysko/dashboard": "workspace:*",
    "@sysko/storage": "workspace:*",
    "@sysko/transport": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
}
